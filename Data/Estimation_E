import pandas as pd
import numpy as np
import os
# 1. Load data
script_dir = os.path.dirname(os.path.abspath(__file__))
file_path = os.path.join(script_dir, 'dataset.csv')
df = pd.read_csv(file_path)

# 2. Identifikasi Bottleneck (Outlier)
# Kita gunakan metode IQR untuk mencari issue yang durasinya di luar batas normal
Q1 = df['duration_days'].quantile(0.25)
Q3 = df['duration_days'].quantile(0.75)
IQR = Q3 - Q1
upper_bound = Q3 + 1.5 * IQR

bottlenecks = df[df['duration_days'] > upper_bound]

print("--- Hasil Analisis Bottleneck (Anggota E) ---")
print(f"Total issue: {len(df)}")
print(f"Jumlah issue yang tergolong bottleneck (outlier): {len(bottlenecks)}")
print(f"Batas durasi normal: {upper_bound:.2f} hari")

# 3. Simpan temuan
bottlenecks.to_csv(os.path.join(script_dir, 'bottleneck_report.csv'), index=False)
print("\nLaporan bottleneck disimpan dalam 'bottleneck_report.csv'")
