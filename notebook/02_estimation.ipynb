import pandas as pd
import numpy as np
import scipy.stats as stats
import matplotlib.pyplot as plt

import os
import pandas as pd


folder_path = r'C:\Users\bully\OneDrive\Desktop\bahasa c dasprog\Stat audit panda\data_clean'
file_name = 'dataset.csv'

# Menggabungkan path folder dengan nama file
full_path = os.path.join(folder_path, file_name)

# Memuat data
try:
    df = pd.read_csv(full_path)
    print("Data berhasil dimuat dari:", full_path)
except FileNotFoundError:
    print(f"Error: File tidak ditemukan di {full_path}. Pastikan dataset.csv ada di folder tersebut.")

# Pastikan duration_days bersih dari nilai kosong
durations = df['duration_days'].dropna()

# 2. Maximum Likelihood Estimation (MLE) untuk Distribusi Eksponensial
# Untuk distribusi eksponensial, estimasi lambda adalah 1 / rata-rata
lambda_mle = 1 / np.mean(durations)
print(f"Estimasi Laju Penyelesaian (Lambda/MLE): {lambda_mle:.4f} issue per hari")

# 3. Menghitung Confidence Interval (95%) menggunakan pendekatan bootstrap
# Ini penting karena data durasi seringkali tidak berdistribusi normal
boot_means = []
for _ in range(1000):
    sample = durations.sample(n=len(durations), replace=True)
    boot_means.append(np.mean(sample))

conf_interval = np.percentile(boot_means, [2.5, 97.5])
print(f"Confidence Interval 95% untuk rata-rata durasi: {conf_interval[0]:.4f} hingga {conf_interval[1]:.4f} hari")

# 4. Visualisasi hasil
plt.hist(durations, bins=50, density=True, alpha=0.6, color='skyblue', label='Data Observasi')
x = np.linspace(0, max(durations), 100)
plt.plot(x, stats.expon.pdf(x, scale=1/lambda_mle), 'r-', lw=2, label='Fit Distribusi Eksponensial')
plt.title('Distribusi Durasi Penyelesaian Issue')
plt.xlabel('Hari')
plt.legend()
plt.show()
